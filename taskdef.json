{
	"family": "my-app",
	"containerDefinitions": [
		{
			"image": "%REPOSITORY_URI%:v_%BUILD_NUMBER%",
			"name": "my-app",
			"cpu": 205,
			"memory": 512,
			"essential": true,
			"portMappings": [
				{
					"containerPort": 80
				}
			],
			"logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/my-app",
                    "awslogs-region": "us-east-2",
                    "awslogs-stream-prefix": "documento-prod-alb-ohio"
                }
            },
      "environment": [
        {
          "name": "ENV",
          "value": "production"
        }
      ]
    }
  ]
}
